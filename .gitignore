# ── .NET build output ─────────────────────────────────────────────────────────
[Bb]in/
[Oo]bj/
out/

# NuGet
*.nupkg
*.snupkg
.nuget/
packages/
project.lock.json
project.fragment.lock.json
artifacts/

# ── Publish output ─────────────────────────────────────────────────────────────
# Built release binaries — generated by `dotnet publish`
publish/

# ── EDS runtime data ──────────────────────────────────────────────────────────
# This directory is created at runtime and contains:
#   - config.toml        (API tokens, driver connection strings — SECRETS)
#   - state.db           (SQLite tracker — ephemeral state)
#   - *.log              (session and import logs)
#   - <session-id>/      (NATS credentials — SECRETS)
#   - import-*/          (temporary export download directories)
data/

# Individual runtime files if placed outside data/
config.toml
state.db
*.creds
*.log

# ── IDE and editor files ───────────────────────────────────────────────────────
# Visual Studio
.vs/
*.user
*.userosscache
*.suo
*.userprefs
*.sln.docstates

# Visual Studio Code
.vscode/
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json
.VSCodeCounter/

# JetBrains Rider
.idea/
*.sln.iml

# ── OS files ──────────────────────────────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini

# Linux
*~

# ── Test results and coverage ──────────────────────────────────────────────────
TestResults/
coverage/
*.coverage
*.coveragexml
lcov.info
[Cc]overage[Rr]eport/

# ── Secrets and local config overrides ────────────────────────────────────────
# Never commit credential or secret files regardless of location
*.key
*.pem
*.p12
*.pfx
*.env
.env.*
secrets.json
appsettings.*.json
!appsettings.json
